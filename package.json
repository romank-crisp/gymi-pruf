{
  "name": "gymi-pruf",
  "version": "0.1.0",
  "description": "Content engine for the Gymi-Vorbereitung Gymnasium entrance-exam prep app",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx scripts/seed.ts",
    "generate:nouns": "bash -c 'set -a && source .env 2>/dev/null && set +a && NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" pnpm exec tsx scripts/generate-slot-items.ts \"$@\"' --",
    "generate:exercises": "bash -c 'set -a && source .env 2>/dev/null && set +a && NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" pnpm exec tsx scripts/generate-exercises.ts \"$@\"' --",
    "generate:teaching": "bash -c 'set -a && source .env 2>/dev/null && set +a && NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" pnpm exec tsx scripts/generate-teaching-material.ts \"$@\"' --",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:unit && pnpm run test:int",
    "test:unit": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts tests/unit",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "pl:dev": "pnpm --dir product-launch-app dev",
    "pl:build": "pnpm --dir product-launch-app build && pnpm --dir product-launch-app/mcp-server build",
    "pl:test": "pnpm --dir product-launch-app test",
    "pl:db:migrate": "pnpm --dir product-launch-app db:migrate",
    "pl:db:seed": "pnpm --dir product-launch-app db:seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@payloadcms/db-postgres": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "@payloadcms/ui": "3.83.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.3",
    "payload": "3.83.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "28.0.0",
    "mermaid": "^11.14.0",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
